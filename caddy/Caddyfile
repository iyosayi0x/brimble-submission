# This handles the Frontend (Vite)
http://localhost {
    reverse_proxy frontend:{$FRONTEND_PORT:5173}
}

# This handles the Backend API
http://api.localhost {
    reverse_proxy backend:8000
}

# This handles the dynamic deployments
http://*.localhost {
    # Extract the 'my-app' part from the URL
    @name header_regexp name Host ^([^.]+)\.localhost$
    
    # Send traffic to the container with that same name
    reverse_proxy {re.name.1}:3000 {
        header_up Host {host}
    }
}